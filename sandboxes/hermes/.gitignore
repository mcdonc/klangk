# Hermes runtime install artifacts (written to the mount by setup.sh).
# These are gitignored, never committed.
hermes-agent/
node/
bin/
.env
config.yaml
gateway.pid
gateway.lock
gateway_state.json
logs/
# Installer markers: --no-skills opt-out flag and the default SOUL.md
# persona. Written by the upstream installer under $HERMES_HOME.
.no-bundled-skills
SOUL.md
