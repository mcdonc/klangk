FROM python:3.13-slim AS base

# Rebuild to pick up latest security patches (CVE-2026-45447 openssl)
RUN apt-get update && apt-get install -y --no-install-recommends \
      bash \
      catatonit \
      coreutils \
      fuse-overlayfs \
      gzip \
      nginx \
      passt \
      podman \
      rsync \
      sqlite3 \
      supervisor \
      tar \
      uidmap \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user matching devenv convention (uid 1000)
RUN groupadd -g 1000 klangk && \
    useradd -u 1000 -g klangk -m -d /home/klangk -s /bin/bash klangk

# ---- venv stage: copy pre-built venv and fix shebangs ----
FROM base AS venv
COPY --from=hostvenv . /home/klangk/venv/
# Rewrite hardcoded shebangs from the build host's python path
# to the container's python3 (handles uvicorn, klangk, etc.)
RUN find /home/klangk/venv/bin -type f -exec \
      sed -i '1s|^#!.*python[0-9.]*$|#!/usr/bin/env python3|' {} + 2>/dev/null; \
    true

# ---- final image ----
FROM base

COPY --from=venv --chown=klangk:klangk /home/klangk/venv /home/klangk/venv

# Backend source
COPY --chown=klangk:klangk src/klangk/klangk /home/klangk/src/klangk/klangk
COPY --chown=klangk:klangk src/klangk/pyproject.toml /home/klangk/src/klangk/pyproject.toml

# Flutter web build output
COPY --chown=klangk:klangk src/frontend/build/web /home/klangk/src/frontend/build/web

# Startup scripts and config
# (scripts/nginx.sh is retired in #1396 — klangkd renders nginx.conf itself.)
COPY --chown=klangk:klangk src/containers/host/entrypoint.sh /home/klangk/bin/entrypoint
COPY --chown=klangk:klangk src/containers/host/supervisord.conf /home/klangk/etc/supervisord.conf

# Version file (generated by scripts/generate-version.sh, copied into build context)
COPY --chown=klangk:klangk version.json /home/klangk/version.json

# Plugins (package.json manifests needed for plugin config at runtime)
COPY --from=plugins --chown=klangk:klangk . /home/klangk/plugins/

# Data directory (volume mount point)
RUN mkdir -p /home/klangk/data && chown klangk:klangk /home/klangk/data

# Rootless podman: fuse-overlayfs for storage on overlayfs-backed filesystems
COPY --chown=klangk:klangk src/containers/host/storage.conf /home/klangk/.config/containers/storage.conf

# Embedded workspace image — loaded into podman on first startup
COPY --from=workspace-image --chown=klangk:klangk workspace.tar /home/klangk/workspace.tar

# Nginx needs writable temp dirs
RUN mkdir -p /tmp/nginx_client_body /tmp/nginx_proxy \
             /tmp/nginx_fastcgi /tmp/nginx_uwsgi /tmp/nginx_scgi && \
    chown -R klangk:klangk /tmp/nginx_*
# Nginx on Debian needs /var/log/nginx writable
RUN mkdir -p /var/log/nginx /var/lib/nginx && \
    chown -R klangk:klangk /var/log/nginx /var/lib/nginx

ENV HOME=/home/klangk
ENV PYTHONPATH=/home/klangk/src/klangk:/home/klangk/venv/lib/python3.13/site-packages
ENV PATH=/home/klangk/bin:/home/klangk/venv/bin:$PATH
# klangkd binds a UDS (not TCP). KLANGK_PORT (browser) + KLANGK_EGRESS_PORT
# (container egress) drive nginx's listeners. KLANGK_LISTEN is the browser
# interface address (#1542).
ENV KLANGK_PORT=8997
ENV KLANGK_EGRESS_PORT=8995
ENV KLANGK_DATA_DIR=/home/klangk/data
ENV KLANGK_PLUGINS_DIR=/home/klangk/plugins
ENV KLANGK_CUSTOMIZE_DIR=/home/klangk/custom
ENV KLANGK_IMAGE_NAME=klangk-workspace
ENV KLANGK_VERSION_FILE=/home/klangk/version.json
# Where klangkd writes the UDS + rendered nginx.conf
ENV KLANGK_STATE_DIR=/tmp/klangk-state
# The image runs klangkd from the source tree
# (PYTHONPATH=/home/klangk/src/klangk), not an installed wheel, so the
# in-package default (klangk/frontend, #1600) doesn't apply -- point at the
# Flutter web build copied into the image above.
ENV KLANGK_FRONTEND_DIR=/home/klangk/src/frontend/build/web

USER klangk
WORKDIR /home/klangk

# Only the browser port is published; the egress port is internal
# (workspace containers reach it via host.containers.internal, not from
# outside the host). uvicorn is UDS-only.
EXPOSE 8997

ENTRYPOINT ["/home/klangk/bin/entrypoint"]
CMD ["start"]
