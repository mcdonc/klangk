# LLM configuration (any OpenAI-compatible provider)
KLANGK_LLM_API_KEY=your-api-key-here
# Must use FQDN or IP — bare hostnames won't resolve (nginx resolver
# doesn't support search domains)
KLANGK_LLM_BASE_URL=https://ollama.com/v1
# Any model available on your provider
KLANGK_LLM_MODEL=gemma4:31b

# Klangk configuration
KLANGK_JWT_SECRET=change-this-to-a-random-secret
KLANGK_DEFAULT_USER=admin@example.com
# Omit to generate a random password on first run
# KLANGK_DEFAULT_PASSWORD=admin

# White-label product name (default: Klangk). Shown in the browser tab
# title, app-bar logo, and outgoing emails. No rebuild required.
# KLANGK_PRODUCT_NAME=Acme Labs

# CORS allowed origins (comma-separated). If unset, derived from
# KLANGK_HOSTING_HOSTNAME or defaults to http://localhost:{KLANGK_NGINX_PORT}.
# KLANGK_CORS_ORIGINS=https://klangk.example.com

# Workspace sudo (default: disabled). Set to true to allow passwordless sudo
# inside workspace containers.
# KLANGK_ALLOW_SUDO=true

# SMTP (optional — enables email delivery for verification, invitations, password reset)
# KLANGK_SMTP_HOST=smtp.gmail.com
# KLANGK_SMTP_PORT=587
# KLANGK_SMTP_USER=you@gmail.com
# KLANGK_SMTP_PASSWORD=your-app-password
# KLANGK_SMTP_FROM=you@gmail.com

# OIDC authentication (optional — see docs at https://mcdonc.github.io/klangk/reference/oidc/)
# KLANGK_OIDC_CONFIG=/path/to/oidc.yaml
# password | oidc | both
# KLANGK_AUTH_MODES=both
