#!/usr/bin/env python3
"""Git credential helper that delegates to the user's browser.

Called by git as: git-credential-klangk get|store|erase

On "get": reads protocol/host/path from stdin. If KLANGK_GITHUB_OAUTH_CLIENT_ID
is set and the host is github.com, runs the GitHub device flow (requesting
the code from GitHub directly, showing it in the browser, and polling for the
token). Otherwise, or on fallback, delegates to the browser for a PAT dialog.
On "store"/"erase": forwards to the bridge so the frontend can update or
clear its credential cache.

Falls through (exit 1) when the bridge is unreachable or the user
cancels, letting git try the next configured helper or prompt.
"""

import json
import os
import subprocess
import sys
import time
import urllib.error
import urllib.parse
import urllib.request

BRIDGE_URL = os.environ.get("KLANGK_BRIDGE_URL", "")
WORKSPACE_TOKEN = os.environ.get("KLANGK_WORKSPACE_TOKEN", "")
TIMEOUT = int(os.environ.get("KLANGK_BRIDGE_TIMEOUT_SECONDS", "30"))
# Device flow codes expire after 15 minutes; the credential get operation
# may block on user interaction (PAT dialog or device flow), so use a much
# longer timeout than the default bridge timeout.
GET_TIMEOUT = int(os.environ.get("KLANGK_CREDENTIAL_GET_TIMEOUT", "900"))
GITHUB_CLIENT_ID = os.environ.get("KLANGK_GITHUB_OAUTH_CLIENT_ID", "").strip()
DEBUG = os.environ.get("GIT_CREDENTIAL_KLANGK_DEBUG", "")


def _debug(msg):
    if DEBUG:
        print(f"git-credential-klangk: {msg}", file=sys.stderr)


def _get_browser_id():
    """Read the current browser ID via klangk-browser-id."""
    try:
        result = subprocess.run(
            ["klangk-browser-id"],
            capture_output=True,
            text=True,
            timeout=5,
        )
        if result.returncode == 0:
            return result.stdout.strip()
    except (OSError, subprocess.TimeoutExpired):
        pass
    return ""


def read_credential_input():
    """Read git credential protocol from stdin (key=value lines)."""
    cred = {}
    for line in sys.stdin:
        line = line.strip()
        if not line:
            break
        if "=" in line:
            key, value = line.split("=", 1)
            cred[key] = value
    return cred


def post_bridge(operation, cred, browser_id, timeout=None, extra=None):
    """POST to the browser-delegate bridge. Returns parsed JSON or None."""
    if timeout is None:
        timeout = TIMEOUT
    payload = {
        "action": "git_credential",
        "browser_id": browser_id,
        "operation": operation,
        "protocol": cred.get("protocol", ""),
        "host": cred.get("host", ""),
    }
    if cred.get("path"):
        payload["path"] = cred["path"]
    if cred.get("username"):
        payload["username"] = cred["username"]
    if cred.get("password"):
        payload["password"] = cred["password"]
    if extra:
        payload.update(extra)

    data = json.dumps(payload).encode()
    headers = {"Content-Type": "application/json"}
    if WORKSPACE_TOKEN:
        headers["Authorization"] = f"Bearer {WORKSPACE_TOKEN}"

    req = urllib.request.Request(
        f"{BRIDGE_URL}/api/browser-delegate",
        data=data,
        headers=headers,
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            body = resp.read()
            _debug(f"bridge response: {body[:500]}")
            return json.loads(body)
    except (urllib.error.URLError, OSError, json.JSONDecodeError, ValueError) as e:
        _debug(f"bridge error: {e}")
        return None


def _github_request_device_code():
    """Request a device code from GitHub. Returns parsed JSON or None."""
    data = urllib.parse.urlencode(
        {"client_id": GITHUB_CLIENT_ID, "scope": "repo"}
    ).encode()
    req = urllib.request.Request(
        "https://github.com/login/device/code",
        data=data,
        headers={"Accept": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            return json.loads(resp.read())
    except (urllib.error.URLError, OSError, json.JSONDecodeError, ValueError) as e:
        _debug(f"device code request error: {e}")
        return None


def _github_poll_token(device_code):
    """Poll GitHub for the access token. Returns parsed JSON or None."""
    data = urllib.parse.urlencode(
        {
            "client_id": GITHUB_CLIENT_ID,
            "device_code": device_code,
            "grant_type": "urn:ietf:params:oauth:grant-type:device_code",
        }
    ).encode()
    req = urllib.request.Request(
        "https://github.com/login/oauth/access_token",
        data=data,
        headers={"Accept": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            return json.loads(resp.read())
    except (urllib.error.URLError, OSError, json.JSONDecodeError, ValueError) as e:
        _debug(f"token poll error: {e}")
        return None


def _handle_device_flow(cred, browser_id):
    """Run the GitHub device flow. Returns (username, password) or None."""
    _debug("starting GitHub device flow")

    code_resp = _github_request_device_code()
    if not code_resp or "device_code" not in code_resp:
        error = code_resp.get("error_description", "") if code_resp else ""
        _debug(f"device code request failed: {error}")
        return None

    device_code = code_resp["device_code"]
    user_code = code_resp["user_code"]
    verification_uri = code_resp["verification_uri"]
    interval = code_resp.get("interval", 5)
    expires_in = code_resp.get("expires_in", 900)

    _debug(f"got device code, user_code={user_code} uri={verification_uri}")

    # Tell the browser to show the code and open the verification page.
    post_bridge(
        "device_flow_show",
        cred,
        browser_id,
        extra={
            "user_code": user_code,
            "verification_uri": verification_uri,
        },
    )

    # Poll GitHub for the token.
    deadline = time.monotonic() + expires_in
    while time.monotonic() < deadline:
        time.sleep(interval)

        resp = _github_poll_token(device_code)
        if not resp:
            continue

        error = resp.get("error")
        if error is None:
            token = resp.get("access_token")
            if token:
                _debug("device flow: got token")
                # Tell browser to dismiss the code UI.
                done_resp = post_bridge("device_flow_done", cred, browser_id)
                _debug(f"device_flow_done response: {done_resp}")
                return ("x-access-token", token)

        if error == "authorization_pending":
            continue
        elif error == "slow_down":
            interval += 5
            _debug(f"device flow: slow_down, interval now {interval}s")
            continue
        elif error == "expired_token":
            _debug("device flow: code expired")
            post_bridge(
                "device_flow_error",
                cred,
                browser_id,
                extra={"error": "Code expired. Please try again."},
            )
            return None
        elif error == "access_denied":
            _debug("device flow: access denied")
            post_bridge(
                "device_flow_error",
                cred,
                browser_id,
                extra={"error": "Authorization denied."},
            )
            return None
        else:
            desc = resp.get("error_description", error)
            _debug(f"device flow: unexpected error: {desc}")
            post_bridge(
                "device_flow_error",
                cred,
                browser_id,
                extra={"error": desc},
            )
            return None

    _debug("device flow: timed out")
    post_bridge(
        "device_flow_error",
        cred,
        browser_id,
        extra={"error": "Code expired. Please try again."},
    )
    return None


def main():
    operation = sys.argv[1] if len(sys.argv) > 1 else ""

    browser_id = _get_browser_id()
    _debug(
        f"operation={operation} BRIDGE_URL={BRIDGE_URL!r} "
        f"BROWSER_ID={browser_id[:8] + '...' if browser_id else '(empty)'}"
    )

    if not BRIDGE_URL or not browser_id:
        _debug("no bridge configured, exiting")
        sys.exit(1)

    cred = read_credential_input()
    _debug(f"cred input: {cred}")

    if operation == "get":
        # Try GitHub device flow first if configured and host is GitHub.
        host = cred.get("host", "")
        if GITHUB_CLIENT_ID and host in ("github.com", "www.github.com"):
            result = _handle_device_flow(cred, browser_id)
            if result:
                print(f"username={result[0]}")
                print(f"password={result[1]}")
                return

        # Fall back to PAT dialog via bridge.
        resp = post_bridge("get", cred, browser_id, timeout=GET_TIMEOUT)
        if not resp:
            sys.exit(1)

        # The bridge wraps the plugin response in {"status": "ok",
        # "result": "<json-string>"}. Unwrap if needed.
        result = resp.get("result")
        if isinstance(result, str):
            try:
                resp = json.loads(result)
            except (json.JSONDecodeError, ValueError):
                pass

        username = resp.get("username", "")
        password = resp.get("password", "")
        if not username or not password:
            sys.exit(1)

        print(f"username={username}")
        print(f"password={password}")

    elif operation in ("store", "erase"):
        post_bridge(operation, cred, browser_id)

    # Unknown operations: exit silently.


if __name__ == "__main__":
    main()
