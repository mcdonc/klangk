# Local dev config for klangkd.
#
# Copy to klangkd.yaml (gitignored) and edit:
#   cp klangkd.yaml.example klangkd.yaml
#
# klangkd reads this via: klangkd --config klangkd.yaml
# devenv's backend process does this automatically.

# --- Deployment shape ---
# port: the browser/proxy port. Set it for full/browser mode (UI at http://localhost:8997).
# Leave unset for headless mode (no browser listener; container-egress only).
port: "8997"
# listen: the browser interface address (rendered only when port is set).
listen: "127.0.0.1"
auth_modes: password

# --- Auth / identity ---
jwt_secret: bark-dev-secret-change-in-production
default_user: admin@example.com
default_password: admin

# --- Server / network ---
egress_port: "8995"
idle_timeout_seconds: "300"

# --- Storage ---
# Both are required (no defaults, #1461). Devenv sets KLANGK_STATE_DIR /
# KLANGK_DATA_DIR in the env (see devenv.nix), so these config-file values
# are redundant in dev but shown for reference. In a real deployment set
# them here or via the env vars.
state_dir: "cmd:echo $DEVENV_STATE/klangk"
data_dir: "cmd:echo $DEVENV_STATE/klangk/data"

# --- Container / workspace ---
image_name: klangk-workspace

# --- Uncomment to enable OIDC ---
# auth_modes: both
# oidc_providers:
#   - id: my-provider
#     display-name: My SSO
#     issuer: https://keycloak.example.com/realms/main
#     client-id: klangk
#     client-secret: changeme

# --- Uncomment for LLM proxy ---
# llm_api_key: your-key-here
# llm_base_url: https://api.example.com/v1
# llm_model: gpt-4
